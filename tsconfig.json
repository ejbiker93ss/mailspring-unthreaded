{
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react",
    "target": "es2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "lib": ["es2017", "dom", "esnext.array"],
    "inlineSourceMap": true,
    "outDir": "lib",
    "baseUrl": "src",
    "skipLibCheck": true
  },
  "include": [
    "src/main.js",
    "src/unthreaded-state.js",
    "src/unthreaded-thread-list.jsx",
    "src/unthreaded-message-list.jsx"
  ],
  "exclude": ["node_modules", "lib"]
}
